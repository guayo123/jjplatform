# ============================================================
#  JJPlatform — variables de entorno para despliegue
#  Copia este archivo como .env y completa los valores
# ============================================================

# Contraseña de la base de datos PostgreSQL
DB_PASSWORD=cambia_esto_por_una_contrasena_segura

# Clave secreta para firmar los tokens JWT
# Debe tener mínimo 32 caracteres — usa una cadena aleatoria
JWT_SECRET=cambia_esto_por_una_clave_secreta_de_al_menos_32_caracteres!!

# IP o dominio del servidor (sin http://, sin slash final)
# Ejemplos: 192.168.1.100  |  mi-servidor.com
SERVER_HOST=localhost
