<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Main activity: no LAUNCHER intent-filter; aliases below provide it. -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
        </activity>

        <!-- Belt-icon aliases — only one is enabled at a time (switched by BeltIconPlugin). -->
        <activity-alias
            android:name=".MainActivityBeltWhite"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_belt_white"
            android:roundIcon="@mipmap/ic_launcher_belt_white_round"
            android:label="@string/title_activity_main"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityBeltBlue"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_belt_blue"
            android:roundIcon="@mipmap/ic_launcher_belt_blue_round"
            android:label="@string/title_activity_main"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityBeltPurple"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_belt_purple"
            android:roundIcon="@mipmap/ic_launcher_belt_purple_round"
            android:label="@string/title_activity_main"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityBeltBrown"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_belt_brown"
            android:roundIcon="@mipmap/ic_launcher_belt_brown_round"
            android:label="@string/title_activity_main"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityBeltBlack"
            android:targetActivity=".MainActivity"
            android:icon="@mipmap/ic_launcher_belt_black"
            android:roundIcon="@mipmap/ic_launcher_belt_black_round"
            android:label="@string/title_activity_main"
            android:exported="true"
            android:enabled="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
